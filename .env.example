# .env.example
# Copy file này thành .env.local và điền giá trị thực

# =============================================
# DATABASE (Supabase / Neon / Local PostgreSQL)
# =============================================
DATABASE_URL="postgresql://user:password@localhost:5432/phuonganh_menu?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/phuonganh_menu?schema=public"

# =============================================
# NEXTAUTH
# =============================================
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# =============================================
# N8N WEBHOOKS (Optional)
# =============================================
N8N_WEBHOOK_BASE_URL=""
N8N_WEBHOOK_SECRET=""

# =============================================
# SUPABASE (nếu dùng Storage cho images)
# =============================================
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
