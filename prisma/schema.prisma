// prisma/schema.prisma
// Hệ thống Thực đơn Online - Nhà hàng Phương Anh
// Version 2.0 - Tháng 3/2026

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Dùng cho Supabase/Neon
}

// =============================================
// USER & AUTHENTICATION
// =============================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // Hashed với bcrypt
  name      String
  phone     String?
  role      UserRole @default(STAFF)
  pin       String?  // PIN 4-6 số cho staff đăng nhập nhanh tại bàn
  isActive  Boolean  @default(true)
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  orders       Order[]
  priceHistory PriceHistory[]
  sessions     Session[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
}

// =============================================
// MENU & CATEGORIES
// =============================================

model Category {
  id        String   @id @default(cuid())
  name      String   // Tiếng Việt
  nameEn    String?  // Tiếng Anh
  slug      String   @unique
  icon      String?  // Emoji hoặc icon name
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  menuItems MenuItem[]

  @@map("categories")
}

model MenuItem {
  id            String   @id @default(cuid())
  categoryId    String
  name          String   // Tiếng Việt
  nameEn        String?  // Tiếng Anh
  slug          String   @unique
  description   String?
  descriptionEn String?
  price         Decimal  @db.Decimal(12, 0) // Giá bán
  originalPrice Decimal? @db.Decimal(12, 0) // Giá gốc (để gạch ngang)
  imageUrl      String?
  tags          String[] @default([]) // ["new", "hot", "best_seller", "vegetarian"]
  isAvailable   Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  category     Category      @relation(fields: [categoryId], references: [id])
  orderItems   OrderItem[]
  comboItems   ComboItem[]
  priceHistory PriceHistory[]

  @@map("menu_items")
}

// =============================================
// COMBO / SET MENU
// =============================================

model Combo {
  id          String    @id @default(cuid())
  name        String
  description String?
  price       Decimal   @db.Decimal(12, 0)
  imageUrl    String?
  validFrom   DateTime?
  validTo     DateTime?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  comboItems ComboItem[]

  @@map("combos")
}

model ComboItem {
  id         String @id @default(cuid())
  comboId    String
  menuItemId String
  quantity   Int    @default(1)

  combo    Combo    @relation(fields: [comboId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@unique([comboId, menuItemId])
  @@map("combo_items")
}

// =============================================
// TABLES & ROOMS
// =============================================

model Table {
  id       String      @id @default(cuid())
  name     String      // "Bàn 1", "Bàn A", "Phòng VIP"
  area     String?     // "Tầng 1", "Sân vườn", "Phòng riêng"
  capacity Int         @default(4)
  status   TableStatus @default(FREE)
  qrCode   String?     @unique // URL QR code
  isActive Boolean     @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  orders Order[]

  @@map("tables")
}

enum TableStatus {
  FREE
  OCCUPIED
  RESERVED
  CLEANING
}

model Room {
  id          String   @id @default(cuid())
  name        String   // "Sảnh Sen", "Phòng Hội Nghị A"
  capacity    Int
  pricePerDay Decimal? @db.Decimal(12, 0)
  equipment   String[] @default([]) // ["projector", "microphone", "ac"]
  images      String[] @default([])
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  banquets Banquet[]

  @@map("rooms")
}

// =============================================
// CUSTOMERS
// =============================================

model Customer {
  id          String   @id @default(cuid())
  name        String
  phone       String   @unique
  email       String?
  visitCount  Int      @default(0)
  totalSpent  Decimal  @default(0) @db.Decimal(12, 0)
  loyaltyPoints Int    @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders   Order[]
  banquets Banquet[]

  @@map("customers")
}

// =============================================
// ORDERS
// =============================================

model Order {
  id          String      @id @default(cuid())
  orderCode   String      @unique // PA-260318-001
  customerId  String?
  staffId     String?
  tableId     String?

  // Thông tin khách (cho đặt bàn online)
  customerName String?
  customerPhone String?
  guestCount   Int?

  orderDate    DateTime    @default(now())
  deliveryTime DateTime?   // Giờ đến / giờ phục vụ
  type         OrderType   @default(DINE_IN)
  status       OrderStatus @default(NEW)

  subtotal  Decimal @default(0) @db.Decimal(12, 0)
  discount  Decimal @default(0) @db.Decimal(12, 0)
  total     Decimal @default(0) @db.Decimal(12, 0)

  note      String?
  metadata  Json?   // Thông tin thêm (loại dịch vụ, phòng yêu cầu...)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  customer   Customer?   @relation(fields: [customerId], references: [id])
  staff      User?       @relation(fields: [staffId], references: [id])
  table      Table?      @relation(fields: [tableId], references: [id])
  orderItems OrderItem[]

  @@map("orders")
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  menuItemId String
  quantity   Int
  unitPrice  Decimal @db.Decimal(12, 0)
  subtotal   Decimal @db.Decimal(12, 0)
  note       String? // Ghi chú cho từng món: "không hành", "ít cay"

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@map("order_items")
}

enum OrderType {
  ONLINE    // Đặt qua web
  DINE_IN   // Tại bàn
  BANQUET   // Tiệc / sự kiện
  TAKEAWAY  // Mang về
}

enum OrderStatus {
  NEW         // Mới tạo
  CONFIRMED   // Đã xác nhận
  PREPARING   // Đang chuẩn bị
  SERVING     // Đang phục vụ
  PAID        // Đã thanh toán
  COMPLETED   // Hoàn thành
  CANCELLED   // Đã hủy
}

// =============================================
// BANQUETS & EVENTS
// =============================================

model Banquet {
  id              String        @id @default(cuid())
  customerId      String?
  roomId          String?
  eventType       String        // "Tiệc cưới", "Sinh nhật", "Hội nghị"
  eventDate       DateTime
  guestCount      Int
  pricePerPerson  Decimal?      @db.Decimal(12, 0)
  menuSet         Json?         // Set menu đã chọn
  totalPrice      Decimal?      @db.Decimal(12, 0)
  depositAmount   Decimal?      @db.Decimal(12, 0) // Đặt cọc
  status          BanquetStatus @default(INQUIRY)
  note            String?
  followUpDate    DateTime?     // Ngày cần follow-up

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id])
  room     Room?     @relation(fields: [roomId], references: [id])

  @@map("banquets")
}

enum BanquetStatus {
  INQUIRY    // Hỏi thông tin
  QUOTED     // Đã báo giá
  CONFIRMED  // Đã xác nhận
  DEPOSITED  // Đã đặt cọc
  COMPLETED  // Đã tổ chức xong
  CANCELLED  // Hủy
}

// =============================================
// PRICE HISTORY
// =============================================

model PriceHistory {
  id         String   @id @default(cuid())
  menuItemId String
  oldPrice   Decimal  @db.Decimal(12, 0)
  newPrice   Decimal  @db.Decimal(12, 0)
  changedBy  String
  reason     String?
  changedAt  DateTime @default(now())

  menuItem MenuItem @relation(fields: [menuItemId], references: [id])
  user     User     @relation(fields: [changedBy], references: [id])

  @@map("price_history")
}

// =============================================
// BANNERS & PROMOTIONS
// =============================================

model Banner {
  id        String    @id @default(cuid())
  title     String
  imageUrl  String
  link      String?
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  validFrom DateTime?
  validTo   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("banners")
}

// =============================================
// SYSTEM SETTINGS
// =============================================

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  group     String   @default("general") // "general", "notification", "payment"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}
